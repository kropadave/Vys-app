{
  "expo": {
    "name": "TeamVYS",
    "slug": "TeamVYS",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "teamvys",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.teamvys.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "TeamVYS ověřuje polohu trenéra jen při zápisu docházky u tělocvičny.",
        "NFCReaderUsageDescription": "TeamVYS čte NFC čip pro automatický zápis docházky dítěte.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.nfc.readersession.formats": [
          "NDEF",
          "TAG",
          "NDEF",
          "TAG"
        ]
      }
    },
    "android": {
      "package": "com.teamvys.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.NFC"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0B0612",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0B0612",
          "dark": {
            "backgroundColor": "#0B0612"
          }
        }
      ],
      "react-native-nfc-manager"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ab43c229-e389-4ebe-87c0-4c9ab7174187"
      }
    }
  }
}
